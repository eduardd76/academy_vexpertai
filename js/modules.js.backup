import json

class NetworkDevice(BaseModel):
    hostname: str
    ip: str
    vlan: int

def parse_with_retry(llm_response: str, max_retries: int = 3):
    """Parse LLM response with retry on validation failure"""

    prompt = llm_response

    for attempt in range(max_retries):
        try:
            # Simulate LLM response (in production, call actual API)
            response_json = json.loads(prompt)

            # Validate with Pydantic
            device = NetworkDevice(**response_json)

            print(f"✅ Success on attempt {attempt + 1}")
            return device

        except (json.JSONDecodeError, ValidationError) as e:
            print(f"❌ Attempt {attempt + 1} failed: {e}")

            if attempt < max_retries - 1:
                # In production, you'd send this back to the LLM
                prompt = f"Previous error: {e}. Please fix the JSON."
                print(f"Retrying with error feedback...\\n")

    print(f"❌ Failed after {max_retries} attempts")
    return None

# Test with invalid data
