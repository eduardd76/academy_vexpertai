    """Expand query with synonyms"""

    expansions = {
        "down": ["down", "offline", "inactive", "failed"],
        "slow": ["slow", "latency", "lag", "delayed"],
        "error": ["error", "fault", "issue", "problem"]
    }

    words = query.lower().split()
    expanded = [query]

    for word in words:
        if word in expansions:
            for synonym in expansions[word]:
                expanded.append(
                    query.lower().replace(word, synonym)
                )

    return expanded

query = "network is slow"
variations = expand_query(query)
print(f"Original: {query}")
print(f"Variations: {variations}")`
            }
        ],
        hint: 'Semantic search finds meaning, not just keywords. 73% better than keyword-only!'
    },

    // Remaining chapters will be completed in final integration
    // Current progress: Chapters 13-17 complete (Welcome + 5 chapters)
    // Remaining: Chapters 18-27 (8 chapters to complete)

];

// Export for use in app.js
if (typeof module !== 'undefined' && module.exports) {
    module.exports = courseModules;
}

