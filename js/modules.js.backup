!pip install sentence-transformers chromadb numpy scikit-learn

from sentence_transformers import SentenceTransformer, util
import chromadb
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
from typing import List, Dict, Tuple
from functools import lru_cache

# ============================================
# SEMANTIC SEARCH ENGINE
# ============================================

class SemanticSearchEngine:
    """Production semantic search for network documentation"""

    def __init__(self, model_name: str = "all-MiniLM-L6-v2"):
        self.model = SentenceTransformer(model_name)
        self.documents = []
        self.embeddings = None
        self.metadata = []

    def add_documents(self, docs: List[str], metadata: List[Dict] = None):
        """Add documents to search index"""

        self.documents.extend(docs)
        self.metadata.extend(metadata or [{}] * len(docs))

        # Generate embeddings
        new_embeddings = self.model.encode(docs, convert_to_tensor=False)

        if self.embeddings is None:
            self.embeddings = new_embeddings
        else:
            self.embeddings = np.vstack([self.embeddings, new_embeddings])

        print(f"✅ Added {len(docs)} documents. Total: {len(self.documents)}")

    def search(self, query: str, k: int = 5, min_score: float = 0.3) -> List[Dict]:
        """
        Semantic search

        Args:
            query: Search query
            k: Number of results
            min_score: Minimum similarity score (0-1)

        Returns:
            List of results with scores
        """

        # Encode query
        query_embedding = self.model.encode(query, convert_to_tensor=False)

        # Calculate cosine similarity with all documents
        similarities = cosine_similarity(
            [query_embedding],
            self.embeddings
        )[0]

        # Get top K results above threshold
        top_indices = np.argsort(similarities)[::-1]

        results = []
        for idx in top_indices:
            if similarities[idx] < min_score:
                continue

            if len(results) >= k:
                break

            results.append({
                "document": self.documents[idx],
                "score": float(similarities[idx]),
                "metadata": self.metadata[idx]
            })

        return results

    def semantic_filter(self, concept: str, k: int = 10) -> List[Dict]:
        """Filter documents by semantic concept"""

        return self.search(concept, k=k)

    def multi_query_search(self, queries: List[str], k: int = 5) -> List[Dict]:
        """Search with multiple query variations"""

        all_results = {}

        for query in queries:
            results = self.search(query, k=k*2)

            for result in results:
                doc = result["document"]
                if doc in all_results:
                    # Boost score if found by multiple queries
                    all_results[doc]["score"] = max(
                        all_results[doc]["score"],
                        result["score"]
                    )
                else:
                    all_results[doc] = result

        # Sort by score
        sorted_results = sorted(
            all_results.values(),
            key=lambda x: x["score"],
            reverse=True
        )[:k]

        return sorted_results

# ============================================
# QUERY EXPANSION
# ============================================

class QueryExpander:
    """Expand queries for better semantic search"""

    def expand_network_query(self, query: str) -> List[str]:
        """Generate query variations for network domain"""

        expansions = {
            "bgp": ["bgp", "border gateway protocol", "as path", "neighbor"],
            "down": ["down", "inactive", "failed", "not operational", "offline"],
            "slow": ["slow", "latency", "performance degradation", "high response time"],
            "config": ["config", "configuration", "settings", "setup"],
            "error": ["error", "failure", "problem", "issue", "fault"]
        }

        query_lower = query.lower()
        expanded = [query]  # Always include original

        for keyword, variations in expansions.items():
            if keyword in query_lower:
                # Create variations
                for variation in variations:
                    expanded.append(query_lower.replace(keyword, variation))

        return list(set(expanded))[:5]  # Max 5 variations

# ============================================
# DOMAIN-ADAPTED SEARCH
# ============================================

class NetworkSemanticSearch:
    """Semantic search optimized for network documentation"""

    def __init__(self):
        self.engine = SemanticSearchEngine()
        self.expander = QueryExpander()
        self.cache = {}

    def add_network_docs(self, configs: Dict[str, str]):
        """Add network configurations"""

        docs = []
        metadata = []

        for device, config in configs.items():
            # Split config into sections
            sections = self._split_config(config)

            for section_name, section_content in sections.items():
                docs.append(section_content)
                metadata.append({
                    "device": device,
                    "section": section_name
                })

        self.engine.add_documents(docs, metadata)

    def _split_config(self, config: str) -> Dict[str, str]:
        """Split config into searchable sections"""

        sections = {
            "full": config,
            "vlans": self._extract_section(config, "vlan"),
            "interfaces": self._extract_section(config, "interface"),
            "routing": self._extract_section(config, "router")
        }

        return {k: v for k, v in sections.items() if v.strip()}

    def _extract_section(self, config: str, keyword: str) -> str:
        """Extract config section"""
        lines = [l for l in config.split("\\n") if keyword in l.lower()]
        return "\\n".join(lines)

    @lru_cache(maxsize=1000)
    def search(self, query: str, k: int = 5) -> List[Dict]:
        """Cached semantic search with query expansion"""

        # Expand query
        expanded_queries = self.expander.expand_network_query(query)

        # Multi-query search
        results = self.engine.multi_query_search(expanded_queries, k=k)

        # Add query info
        for result in results:
            result["original_query"] = query
            result["expanded_queries"] = expanded_queries

        return results

    def troubleshooting_search(self, symptom: str) -> List[Dict]:
        """Specialized search for troubleshooting"""

        # Add troubleshooting context
        query = f"troubleshooting {symptom} problem solution fix"

        return self.search(query, k=10)

# ============================================
# SEMANTIC SIMILARITY ANALYSIS
# ============================================

class SemanticAnalyzer:
    """Analyze semantic relationships"""

    def __init__(self, model: SentenceTransformer):
        self.model = model

    def compare_documents(self, doc1: str, doc2: str) -> float:
        """Calculate semantic similarity between two documents"""

        emb1 = self.model.encode(doc1)
        emb2 = self.model.encode(doc2)

        similarity = cosine_similarity([emb1], [emb2])[0][0]

        return float(similarity)

    def find_similar_configs(self, reference_config: str,
                           configs: List[str], threshold: float = 0.8) -> List[Tuple]:
        """Find configs similar to reference"""

        ref_emb = self.model.encode(reference_config)
        config_embs = self.model.encode(configs)

        similarities = cosine_similarity([ref_emb], config_embs)[0]

        similar = [
            (configs[i], float(similarities[i]))
            for i in range(len(configs))
            if similarities[i] >= threshold
        ]

        similar.sort(key=lambda x: x[1], reverse=True)

        return similar

    def cluster_documents(self, documents: List[str], n_clusters: int = 5) -> Dict:
        """Cluster documents by semantic similarity"""

        from sklearn.cluster import KMeans

        # Encode documents
        embeddings = self.model.encode(documents)

        # Cluster
        kmeans = KMeans(n_clusters=n_clusters, random_state=42)
        labels = kmeans.fit_predict(embeddings)

        # Group by cluster
        clusters = {}
        for i, label in enumerate(labels):
            if label not in clusters:
                clusters[label] = []
            clusters[label].append(documents[i])

        return clusters

# ============================================
# EXAMPLE USAGE
# ============================================

# Sample network documentation
sample_docs = [
    "RTR-01 BGP configuration: router bgp 65001, neighbor 10.1.1.2 remote-as 65002, peer established",
    "SW-01 VLAN configuration: vlan 10 name USERS, vlan 20 name SERVERS, all VLANs operational",
    "RTR-02 OSPF configuration: router ospf 1, network 10.0.0.0 area 0, adjacencies formed",
    "SW-02 interface down: GigabitEthernet0/1 status down, line protocol down, admin shutdown",
    "RTR-03 high CPU: CPU utilization 95%, OSPF process consuming resources",
    "SW-03 performance issue: slow response times, high latency observed on trunk links"
]

# Initialize semantic search
