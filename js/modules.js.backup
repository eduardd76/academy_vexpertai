from io import StringIO

template = """Value INTERFACE (\\S+)
Value IP (\\d+\\.\\d+\\.\\d+\\.\\d+)
Value STATUS (up|down)

Start
  ^\\s*\${INTERFACE}\\s+\${IP}.*\${STATUS} -> Record"""

output = """GigabitEthernet0/0  192.168.1.1  up
GigabitEthernet0/1  10.0.0.1     up"""

fsm = textfsm.TextFSM(StringIO(template))
results = fsm.ParseText(output)

for row in results:
    print(dict(zip(['interface', 'ip', 'status'], row)))`
