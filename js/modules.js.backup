        code: `# Chapter 11: Testing And Validation - Complete Implementation

!pip install anthropic pytest python-dotenv

import os
import json
from typing import List, Dict
from anthropic import Anthropic
import pytest

client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

# ============================================
# TESTABLE AI SYSTEM
# ============================================

class ConfigAnalyzer:
    """AI-powered config analyzer with testing support"""

    def __init__(self, anthropic_client):
        self.client = anthropic_client
        self.system_prompt = """You are a network security expert.
Analyze configurations and identify vulnerabilities."""

    def analyze_security(self, config: str) -> Dict:
        """Analyze config for security issues"""

        prompt = f"""Analyze this Cisco IOS config for security issues:

{config}

Return JSON: {{"severity": "LOW|MEDIUM|HIGH|CRITICAL", "issues": ["..."]}}"""

        response = self.client.messages.create(
            model="claude-3-5-sonnet-20241022",
            max_tokens=1500,
            temperature=0,
            system=self.system_prompt,
            messages=[{"role": "user", "content": prompt}]
        )

        # Parse response
        return {
            'response': response.content[0].text,
            'model': 'claude-3-5-sonnet-20241022'
        }

# ============================================
# LEVEL 1: PROMPT TESTS
# ============================================

class TestConfigAnalyzer:
    """Unit tests for AI config analyzer"""

    @pytest.fixture
    def analyzer(self):
        return ConfigAnalyzer(client)

    def test_detects_telnet(self, analyzer):
        """Should detect telnet vulnerability"""
        config = """hostname Router1
line vty 0 4
 transport input telnet
 password weak123"""

        result = analyzer.analyze_security(config)
        response_lower = result['response'].lower()

        # Semantic assertions (not exact match)
        assert 'telnet' in response_lower, "Should mention telnet"
        assert any(word in response_lower for word in ['insecure', 'vulnerable', 'risk']), \
            "Should indicate security concern"

    def test_detects_weak_password(self, analyzer):
        """Should detect weak password"""
        config = """enable password cisco123"""

        result = analyzer.analyze_security(config)
        response_lower = result['response'].lower()

        assert 'password' in response_lower
        assert any(word in response_lower for word in ['weak', 'simple', 'insecure'])

    def test_empty_config(self, analyzer):
        """Should handle empty config gracefully"""
        result = analyzer.analyze_security("")

        assert result is not None
        assert 'error' not in result.get('response', '').lower()

# ============================================
# LEVEL 2: REGRESSION TESTS
# ============================================

class RegressionTester:
    """Detect behavioral changes across model updates"""

    def __init__(self, baseline_file: str = "baseline.json"):
        self.baseline_file = baseline_file
        self.baseline = self.load_baseline()

    def load_baseline(self) -> Dict:
        """Load baseline results"""
        try:
            with open(self.baseline_file, 'r') as f:
                return json.load(f)
        except FileNotFoundError:
            return {}

    def save_baseline(self, results: Dict):
        """Save new baseline"""
        with open(self.baseline_file, 'w') as f:
            json.dump(results, f, indent=2)

    def run_test_suite(self, analyzer: ConfigAnalyzer, test_configs: List[Dict]) -> Dict:
        """Run full test suite and compare to baseline"""

        results = {}

        for test in test_configs:
            test_id = test['id']
            config = test['config']

            print(f"Testing: {test_id}")
            response = analyzer.analyze_security(config)

            results[test_id] = {
                'response': response['response'],
                'keywords': self.extract_keywords(response['response'])
            }

        return results

    def extract_keywords(self, text: str) -> List[str]:
        """Extract key security terms"""
        keywords = []
        security_terms = ['critical', 'high', 'medium', 'low', 'telnet', 'ssh',
                         'password', 'weak', 'vulnerability', 'insecure']

        text_lower = text.lower()
        for term in security_terms:
            if term in text_lower:
                keywords.append(term)

        return keywords

    def compare_to_baseline(self, current_results: Dict) -> Dict:
        """Compare current results to baseline"""

        if not self.baseline:
            print("⚠️ No baseline found - saving current results as baseline")
            self.save_baseline(current_results)
            return {'status': 'baseline_created'}

        regressions = []

        for test_id, current in current_results.items():
            if test_id not in self.baseline:
                print(f"⚠️ New test: {test_id}")
                continue

            baseline = self.baseline[test_id]

            # Compare keywords
            baseline_keywords = set(baseline['keywords'])
            current_keywords = set(current['keywords'])

            missing = baseline_keywords - current_keywords
            new = current_keywords - baseline_keywords

            if missing:
                regressions.append({
                    'test_id': test_id,
                    'type': 'missing_keywords',
                    'missing': list(missing),
                    'severity': 'HIGH' if 'critical' in missing else 'MEDIUM'
                })

        return {
            'status': 'regression_detected' if regressions else 'passed',
            'regressions': regressions,
            'total_tests': len(current_results)
        }

# ============================================
# LEVEL 3: QUALITY METRICS
# ============================================

class QualityMetrics:
    """Calculate AI system quality metrics"""

    def calculate_accuracy(self, predictions: List[bool], actuals: List[bool]) -> float:
        """Calculate accuracy"""
        correct = sum(p == a for p, a in zip(predictions, actuals))
        return correct / len(predictions) if predictions else 0

    def calculate_precision(self, true_pos: int, false_pos: int) -> float:
        """Calculate precision"""
        total = true_pos + false_pos
        return true_pos / total if total > 0 else 0

    def calculate_recall(self, true_pos: int, false_neg: int) -> float:
        """Calculate recall"""
        total = true_pos + false_neg
        return true_pos / total if total > 0 else 0

    def calculate_f1(self, precision: float, recall: float) -> float:
        """Calculate F1 score"""
        if precision + recall == 0:
            return 0
        return 2 * (precision * recall) / (precision + recall)

    def evaluate_classifier(self, results: List[Dict]) -> Dict:
        """
        Evaluate classification performance.

        Args:
            results: List of {prediction: bool, actual: bool}

        Returns:
            Metrics dictionary
        """
        true_pos = sum(1 for r in results if r['prediction'] and r['actual'])
        false_pos = sum(1 for r in results if r['prediction'] and not r['actual'])
        false_neg = sum(1 for r in results if not r['prediction'] and r['actual'])
        true_neg = sum(1 for r in results if not r['prediction'] and not r['actual'])

        precision = self.calculate_precision(true_pos, false_pos)
        recall = self.calculate_recall(true_pos, false_neg)
        f1 = self.calculate_f1(precision, recall)
        accuracy = (true_pos + true_neg) / len(results) if results else 0

        return {
            'accuracy': accuracy,
            'precision': precision,
            'recall': recall,
            'f1_score': f1,
            'true_positives': true_pos,
            'false_positives': false_pos,
            'false_negatives': false_neg,
            'true_negatives': true_neg
        }

# ============================================
# EXAMPLE USAGE
# ============================================

if __name__ == "__main__":
    print("="*70)
    print("AI TESTING & VALIDATION DEMONSTRATION")
