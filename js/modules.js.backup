        code: `# Chapter 14: RAG Fundamentals - Complete Implementation

!pip install langchain chromadb openai anthropic sentence-transformers

import os
from typing import List, Dict
from openai import OpenAI
from anthropic import Anthropic
import chromadb
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain.embeddings import OpenAIEmbeddings
from langchain.vectorstores import Chroma
from langchain.docstore.document import Document

# Initialize clients
openai_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
anthropic_client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

# ============================================
# DOCUMENT CHUNKER
# ============================================

class NetworkDocumentChunker:
    """Intelligently chunk network documentation"""

    def __init__(self, chunk_size: int = 500, chunk_overlap: int = 50):
        self.splitter = RecursiveCharacterTextSplitter(
            chunk_size=chunk_size,
            chunk_overlap=chunk_overlap,
            separators=["\\n\\n", "\\n", " ", ""]
        )

    def chunk_by_device(self, configs: Dict[str, str]) -> List[Document]:
        """Chunk configurations by device"""

        documents = []

        for device_name, config in configs.items():
            # Split config into chunks
            chunks = self.splitter.split_text(config)

            for i, chunk in enumerate(chunks):
                doc = Document(
                    page_content=chunk,
                    metadata={
                        "device": device_name,
                        "chunk": i,
                        "total_chunks": len(chunks)
                    }
                )
                documents.append(doc)

        return documents

    def chunk_by_section(self, config: str, device_name: str) -> List[Document]:
        """Chunk by configuration sections (VLANs, interfaces, routing)"""

        sections = {
            "vlans": self._extract_section(config, "vlan"),
            "interfaces": self._extract_section(config, "interface"),
            "routing": self._extract_section(config, "router"),
            "acls": self._extract_section(config, "access-list")
        }

        documents = []

        for section_name, section_content in sections.items():
            if section_content:
                doc = Document(
                    page_content=section_content,
                    metadata={
                        "device": device_name,
                        "section": section_name
                    }
                )
                documents.append(doc)

        return documents

    def _extract_section(self, config: str, keyword: str) -> str:
        """Extract configuration section by keyword"""

        lines = config.split("\\n")
        section_lines = []
        in_section = False

        for line in lines:
            if keyword in line.lower():
                in_section = True
            elif in_section and line and not line.startswith(" "):
                in_section = False

            if in_section:
                section_lines.append(line)

        return "\\n".join(section_lines)

# ============================================
# RAG SYSTEM
# ============================================

class NetworkRAGSystem:
    """Complete RAG system for network documentation"""

    def __init__(self, persist_directory: str = "./network_rag_db"):
        self.persist_directory = persist_directory
        self.embeddings = OpenAIEmbeddings(
            model="text-embedding-3-small"
        )
        self.chunker = NetworkDocumentChunker()
        self.vectorstore = None

    def ingest_documents(self, configs: Dict[str, str]):
        """Ingest network configurations into RAG system"""

        print(f"📥 Ingesting {len(configs)} device configurations...")

        # Chunk documents
        documents = self.chunker.chunk_by_device(configs)
        print(f"✂️  Created {len(documents)} chunks")

        # Create vector store
        self.vectorstore = Chroma.from_documents(
            documents=documents,
            embedding=self.embeddings,
            persist_directory=self.persist_directory
        )

        print(f"✅ Documents ingested successfully!")

    def load_existing(self):
        """Load existing vector database"""

        self.vectorstore = Chroma(
            persist_directory=self.persist_directory,
            embedding_function=self.embeddings
        )

        print("✅ Loaded existing RAG database")

    def retrieve(self, query: str, k: int = 3, filter_dict: Dict = None) -> List[Document]:
        """Retrieve relevant documents"""

        if not self.vectorstore:
            raise ValueError("Vector store not initialized. Call ingest_documents() first.")

        search_kwargs = {"k": k}
        if filter_dict:
            search_kwargs["filter"] = filter_dict

        results = self.vectorstore.similarity_search(query, **search_kwargs)

        return results

    def answer_question(self, question: str, k: int = 3) -> Dict:
        """Answer question using RAG"""

        # Retrieve relevant documents
        relevant_docs = self.retrieve(question, k=k)

        # Build context
        context = "\\n\\n".join([
            f"[Source: {doc.metadata.get('device', 'Unknown')}]\\n{doc.page_content}"
            for doc in relevant_docs
        ])

        # Build prompt
        prompt = f"""You are a network documentation assistant. Answer the question based ONLY on the provided context.

Context:
{context}

Question: {question}

Instructions:
1. Answer based solely on the context provided
2. If the answer is not in the context, say "I don't have that information in the documentation"
3. Cite the source device when possible
4. Be concise but complete

Answer:"""

        # Get response from Claude
        response = anthropic_client.messages.create(
            model="claude-3-5-sonnet-20241022",
            max_tokens=1000,
            messages=[{"role": "user", "content": prompt}]
        )

        answer = response.content[0].text

        return {
            "question": question,
            "answer": answer,
            "sources": [doc.metadata for doc in relevant_docs],
            "num_sources": len(relevant_docs)
        }

    def batch_questions(self, questions: List[str]) -> List[Dict]:
        """Answer multiple questions efficiently"""

        results = []

        for question in questions:
            result = self.answer_question(question)
            results.append(result)

        return results

# ============================================
# ADVANCED RETRIEVAL
# ============================================

class AdvancedRetriever:
    """Advanced retrieval strategies"""

    def __init__(self, vectorstore):
        self.vectorstore = vectorstore

    def mmr_search(self, query: str, k: int = 3, diversity: float = 0.5) -> List[Document]:
        """Maximal Marginal Relevance search for diverse results"""

        results = self.vectorstore.max_marginal_relevance_search(
            query,
            k=k,
            fetch_k=k*3,  # Fetch more candidates
            lambda_mult=diversity  # 0 = max diversity, 1 = max relevance
        )

        return results

    def filtered_search(self, query: str, device_type: str = None,
                       location: str = None, k: int = 3) -> List[Document]:
        """Search with metadata filters"""

        filter_dict = {}
        if device_type:
            filter_dict["device_type"] = device_type
        if location:
            filter_dict["location"] = location

        if filter_dict:
            results = self.vectorstore.similarity_search(
                query,
                k=k,
                filter=filter_dict
            )
        else:
            results = self.vectorstore.similarity_search(query, k=k)

        return results

    def hybrid_search(self, query: str, k: int = 3) -> List[Document]:
        """Combine vector and keyword search"""

        # Vector search
        vector_results = self.vectorstore.similarity_search(query, k=k)

        # Simple keyword search (in real implementation, use BM25)
        keyword_results = []
        all_docs = self.vectorstore.get()  # Get all documents
        for doc in all_docs.get('documents', []):
            if any(word.lower() in doc.lower() for word in query.split()):
                keyword_results.append(doc)

        # Combine and deduplicate
        combined = vector_results  # Simplified for example

        return combined[:k]

# ============================================
# RAG EVALUATION
# ============================================

class RAGEvaluator:
    """Evaluate RAG system performance"""

    def __init__(self, rag_system: NetworkRAGSystem):
        self.rag_system = rag_system

    def test_retrieval_accuracy(self, test_cases: List[Dict]) -> Dict:
        """Test if correct documents are retrieved"""

        correct = 0
        total = len(test_cases)

        for test in test_cases:
            query = test["query"]
            expected_device = test["expected_device"]

            results = self.rag_system.retrieve(query, k=3)
            retrieved_devices = [doc.metadata.get("device") for doc in results]

            if expected_device in retrieved_devices:
                correct += 1

        accuracy = correct / total if total > 0 else 0

        return {
            "retrieval_accuracy": accuracy,
            "correct": correct,
            "total": total
        }

    def test_answer_accuracy(self, test_cases: List[Dict]) -> Dict:
        """Test if answers are correct"""

        correct = 0
        total = len(test_cases)

        for test in test_cases:
            result = self.rag_system.answer_question(test["query"])
            answer = result["answer"].lower()

            # Check if expected keywords are in answer
            expected_keywords = test.get("expected_keywords", [])
            if all(keyword.lower() in answer for keyword in expected_keywords):
                correct += 1

        accuracy = correct / total if total > 0 else 0

        return {
            "answer_accuracy": accuracy,
            "correct": correct,
            "total": total
        }

