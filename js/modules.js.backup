import os
import re
import json
from typing import List, Dict, Tuple
from anthropic import Anthropic
import tiktoken
from datetime import datetime

# Initialize Anthropic client
client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

# ============================================
# SECTION 1: TOKEN COUNTING
# ============================================

def count_tokens(text: str, model: str = "claude-3-5-sonnet-20241022") -> int:
    """
    Count tokens in text using tiktoken.

    Args:
        text: Input text to count
        model: Model name for token encoding

    Returns:
        Token count
    """
    # Use cl100k_base encoding (similar to Claude)
    encoding = tiktoken.get_encoding("cl100k_base")
    return len(encoding.encode(text))


def calculate_safe_chunk_size(
    max_context: int = 200000,
    system_prompt_tokens: int = 2000,
    output_tokens: int = 5000,
    safety_margin: float = 0.2
) -> int:
    """
    Calculate safe chunk size accounting for overhead.

    Args:
        max_context: Maximum context window (200K for Claude Sonnet)
        system_prompt_tokens: Tokens used by system instructions
        output_tokens: Expected output size
        safety_margin: Reserve percentage (0.2 = 20%)

    Returns:
        Safe chunk size in tokens
    """
    usable_tokens = max_context - system_prompt_tokens - output_tokens
    safe_size = int(usable_tokens * (1 - safety_margin))

    print(f"Max Context: {max_context:,} tokens")
    print(f"System Prompt: {system_prompt_tokens:,} tokens")
    print(f"Expected Output: {output_tokens:,} tokens")
    print(f"Safety Margin: {safety_margin*100}%")
    print(f"Safe Chunk Size: {safe_size:,} tokens")

    return safe_size


# ============================================
# SECTION 2: SEMANTIC CHUNKING
# ============================================

class ConfigSection:
    """Represents a semantic section of network configuration"""

    def __init__(self, section_type: str, content: str, start_line: int):
        self.section_type = section_type
        self.content = content
        self.start_line = start_line
        self.token_count = count_tokens(content)

    def __repr__(self):
        return f"<ConfigSection {self.section_type} ({self.token_count} tokens)>"


def parse_cisco_config_sections(config: str) -> List[ConfigSection]:
    """
    Parse Cisco IOS config into semantic sections.

    Recognizes:
    - Interface blocks
    - Router protocol blocks (BGP, OSPF, EIGRP)
    - Access-list definitions
    - Class-map and policy-map definitions
    - Line configurations
    - Other sections

    Args:
        config: Full Cisco IOS configuration

    Returns:
        List of ConfigSection objects
    """
    sections = []
    lines = config.split('\\n')

    current_section = None
    current_type = None
    current_content = []
    start_line = 0

    for i, line in enumerate(lines, 1):
        # Detect section starts
        if re.match(r'^interface ', line):
            if current_content:
                sections.append(ConfigSection(current_type, '\\n'.join(current_content), start_line))
            current_type = 'interface'
            current_content = [line]
            start_line = i

        elif re.match(r'^router (bgp|ospf|eigrp|rip)', line):
            if current_content:
                sections.append(ConfigSection(current_type, '\\n'.join(current_content), start_line))
            current_type = 'routing'
            current_content = [line]
            start_line = i

        elif re.match(r'^(ip )?access-list', line):
            if current_content:
                sections.append(ConfigSection(current_type, '\\n'.join(current_content), start_line))
            current_type = 'acl'
            current_content = [line]
            start_line = i

        elif re.match(r'^(class-map|policy-map)', line):
            if current_content:
                sections.append(ConfigSection(current_type, '\\n'.join(current_content), start_line))
            current_type = 'qos'
            current_content = [line]
            start_line = i

        elif re.match(r'^line (vty|console|aux)', line):
            if current_content:
                sections.append(ConfigSection(current_type, '\\n'.join(current_content), start_line))
            current_type = 'line'
            current_content = [line]
            start_line = i

        elif line.strip() == '!':
            # End of section marker
            if current_content:
                current_content.append(line)
                sections.append(ConfigSection(current_type or 'general', '\\n'.join(current_content), start_line))
                current_content = []
                current_type = None

        else:
            # Continue current section
            if current_content or line.strip():
                current_content.append(line)
                if not current_type:
                    current_type = 'general'
                    start_line = i

    # Add final section
    if current_content:
        sections.append(ConfigSection(current_type or 'general', '\\n'.join(current_content), start_line))

    return sections


def create_semantic_chunks(
    sections: List[ConfigSection],
    max_tokens: int = 150000,
    overlap_tokens: int = 5000
) -> List[Dict]:
    """
    Combine sections into chunks that fit within token limits.
    Includes overlap between chunks for context continuity.

    Args:
        sections: List of ConfigSection objects
        max_tokens: Maximum tokens per chunk
        overlap_tokens: Token overlap between chunks

    Returns:
        List of chunk dictionaries with metadata
    """
    chunks = []
    current_chunk = []
    current_tokens = 0
    previous_sections = []  # For overlap

    for section in sections:
        # Check if adding this section would exceed limit
        if current_tokens + section.token_count > max_tokens and current_chunk:
            # Save current chunk
            chunk_content = '\\n'.join([s.content for s in current_chunk])
            chunks.append({
                'chunk_id': len(chunks) + 1,
                'content': chunk_content,
                'token_count': current_tokens,
                'section_types': [s.section_type for s in current_chunk],
                'line_range': (current_chunk[0].start_line, current_chunk[-1].start_line)
            })

            # Create overlap from end of current chunk
            overlap_sections = []
            overlap_tokens = 0
            for s in reversed(current_chunk):
                if overlap_tokens + s.token_count <= overlap_tokens:
                    overlap_sections.insert(0, s)
                    overlap_tokens += s.token_count
                else:
                    break

            # Start new chunk with overlap
            current_chunk = overlap_sections + [section]
            current_tokens = overlap_tokens + section.token_count
        else:
            current_chunk.append(section)
            current_tokens += section.token_count

    # Add final chunk
    if current_chunk:
        chunk_content = '\\n'.join([s.content for s in current_chunk])
        chunks.append({
            'chunk_id': len(chunks) + 1,
            'content': chunk_content,
            'token_count': current_tokens,
            'section_types': [s.section_type for s in current_chunk],
            'line_range': (current_chunk[0].start_line, current_chunk[-1].start_line)
        })

    return chunks


# ============================================
# SECTION 3: MAP-REDUCE PATTERN
# ============================================

def analyze_chunk(chunk: Dict, system_prompt: str) -> Dict:
    """
    Analyze a single configuration chunk using Claude.

    Args:
        chunk: Chunk dictionary with content and metadata
        system_prompt: Analysis instructions

    Returns:
        Analysis results dictionary
    """
    print(f"\\nAnalyzing chunk {chunk['chunk_id']} ({chunk['token_count']:,} tokens)...")

    user_prompt = f"""Analyze this network configuration chunk for security issues.

Chunk ID: {chunk['chunk_id']}
Line Range: {chunk['line_range'][0]}-{chunk['line_range'][1]}
Section Types: {', '.join(set(chunk['section_types']))}

Configuration:
{chunk['content']}

Return JSON with format:
{{
    "chunk_id": {chunk['chunk_id']},
    "issues": [
        {{
            "severity": "CRITICAL|HIGH|MEDIUM|LOW",
            "category": "security|best-practice|performance",
            "line_range": "start-end",
            "issue": "description",
            "recommendation": "fix"
        }}
    ]
}}"""

    try:
        response = client.messages.create(
            model="claude-3-5-sonnet-20241022",
            max_tokens=5000,
            temperature=0,
            system=system_prompt,
            messages=[{"role": "user", "content": user_prompt}]
        )

        # Extract JSON from response
        response_text = response.content[0].text
        json_match = re.search(r'\\{.*\\}', response_text, re.DOTALL)

        if json_match:
            result = json.loads(json_match.group())
            print(f"  Found {len(result.get('issues', []))} issues")
            return result
        else:
            print("  ❌ No valid JSON in response")
            return {"chunk_id": chunk['chunk_id'], "issues": []}

    except Exception as e:
        print(f"  ❌ Error analyzing chunk: {e}")
        return {"chunk_id": chunk['chunk_id'], "issues": [], "error": str(e)}


def reduce_results(chunk_results: List[Dict]) -> Dict:
    """
    Aggregate and deduplicate results from all chunks.

    Args:
        chunk_results: List of analysis results from each chunk

    Returns:
        Consolidated analysis report
    """
    print(f"\\n{'='*70}")
    print("REDUCING RESULTS")
    print('='*70)

    all_issues = []
    for result in chunk_results:
        for issue in result.get('issues', []):
            # Add chunk context to each issue
            issue['chunk_id'] = result['chunk_id']
            all_issues.append(issue)

    # Sort by severity
    severity_order = {'CRITICAL': 0, 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3}
    all_issues.sort(key=lambda x: severity_order.get(x['severity'], 4))

    # Count by severity
    severity_counts = {}
    for issue in all_issues:
        severity = issue['severity']
        severity_counts[severity] = severity_counts.get(severity, 0) + 1

    # Create final report
    report = {
        'timestamp': datetime.now().isoformat(),
        'total_chunks': len(chunk_results),
        'total_issues': len(all_issues),
        'severity_counts': severity_counts,
        'issues': all_issues
    }

    return report


def map_reduce_analysis(config: str) -> Dict:
    """
    Complete Map-Reduce analysis pipeline.

    Args:
        config: Full network configuration

    Returns:
        Consolidated analysis report
    """
    print("="*70)
    print("MAP-REDUCE CONFIG ANALYSIS PIPELINE")
    print("="*70)

    # Step 1: Calculate safe chunk size
    safe_chunk_size = calculate_safe_chunk_size()

    # Step 2: Parse into semantic sections
    print(f"\\nParsing configuration into semantic sections...")
    sections = parse_cisco_config_sections(config)
    print(f"  Found {len(sections)} sections")

    # Step 3: Create chunks
    print(f"\\nCreating chunks (max {safe_chunk_size:,} tokens)...")
    chunks = create_semantic_chunks(sections, max_tokens=safe_chunk_size)
    print(f"  Created {len(chunks)} chunks")

    for chunk in chunks:
        print(f"  Chunk {chunk['chunk_id']}: {chunk['token_count']:,} tokens, "
              f"lines {chunk['line_range'][0]}-{chunk['line_range'][1]}")

    # Step 4: MAP - Analyze each chunk
    print(f"\\n{'='*70}")
    print("MAP PHASE: Analyzing chunks")
    print('='*70)

    system_prompt = """You are a network security expert analyzing Cisco IOS configurations.
Identify security vulnerabilities, best-practice violations, and performance issues.
Be specific about line numbers and provide actionable recommendations."""

    chunk_results = []
    for chunk in chunks:
        result = analyze_chunk(chunk, system_prompt)
        chunk_results.append(result)

    # Step 5: REDUCE - Aggregate results
    final_report = reduce_results(chunk_results)

    return final_report


# ============================================
# SECTION 4: PROMPT CACHING
# ============================================

def analyze_with_caching(config: str, knowledge_base: str) -> Dict:
    """
    Analyze configuration using prompt caching for knowledge base.

    The knowledge base (best practices, standards) is cached and reused
    across multiple requests within a 5-minute window.

    Args:
        config: Network configuration to analyze
        knowledge_base: Static reference content (will be cached)

    Returns:
        Analysis results
    """
    print("\\nAnalyzing with prompt caching...")

    # System prompt with cached knowledge base
    system_blocks = [
        {
            "type": "text",
            "text": """You are a network security expert. Use the provided knowledge base
to analyze configurations against industry best practices."""
        },
        {
            "type": "text",
            "text": knowledge_base,
            "cache_control": {"type": "ephemeral"}  # Cache this block
        }
    ]

    user_prompt = f"""Analyze this Cisco IOS configuration:

{config}

Identify security issues and best-practice violations based on the knowledge base.
Return results as JSON with issues list."""

    try:
        response = client.messages.create(
            model="claude-3-5-sonnet-20241022",
            max_tokens=3000,
            temperature=0,
            system=system_blocks,
            messages=[{"role": "user", "content": user_prompt}]
        )

        # Check cache usage
        usage = response.usage
        print(f"\\nToken Usage:")
        print(f"  Input tokens: {usage.input_tokens}")
        print(f"  Cache creation tokens: {getattr(usage, 'cache_creation_input_tokens', 0)}")
        print(f"  Cache read tokens: {getattr(usage, 'cache_read_input_tokens', 0)}")
        print(f"  Output tokens: {usage.output_tokens}")

        # Calculate cost savings
        if hasattr(usage, 'cache_read_input_tokens') and usage.cache_read_input_tokens > 0:
            regular_cost = (usage.input_tokens + usage.cache_read_input_tokens) * 3.00 / 1_000_000
            cached_cost = (usage.input_tokens * 3.00 + usage.cache_read_input_tokens * 0.30) / 1_000_000
            savings = regular_cost - cached_cost
            print(f"\\nCost Savings:")
            print(f"  Without caching: \${regular_cost:.4f}")
            print(f"  With caching: \${cached_cost:.4f}")
            print(f"  Savings: \${savings:.4f} ({savings/regular_cost*100:.1f}%)")

        return {"response": response.content[0].text, "usage": usage}

    except Exception as e:
        print(f"❌ Error: {e}")
        return {"error": str(e)}


