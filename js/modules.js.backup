def sanitize_config(config: str) -> str:
    """Remove credentials from config"""

    patterns = {
        r'enable secret .*': 'enable secret [REDACTED]',
        r'password .*': 'password [REDACTED]',
        r'snmp-server community \\S+': 'snmp-server community [REDACTED]',
        r'key .*': 'key [REDACTED]'
    }

    sanitized = config
    for pattern, replacement in patterns.items():
        sanitized = re.sub(pattern, replacement, sanitized)

    return sanitized

