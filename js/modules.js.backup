# AGENT WITH MEMORY
# ============================================

class NetworkAgentWithMemory:
    """Agent that remembers conversation history"""

    def __init__(self):
        self.llm = ChatOpenAI(model="gpt-4", temperature=0)
        self.tools = [
            execute_show_command,
            search_documentation,
            check_device_logs
        ]

        # Add memory
        self.memory = ConversationBufferMemory(
            memory_key="chat_history",
            return_messages=True
        )

        self.prompt = hub.pull("hwchase17/openai-tools-agent")

        self.agent = create_openai_tools_agent(
            self.llm,
            self.tools,
            self.prompt
        )

        self.agent_executor = AgentExecutor(
            agent=self.agent,
            tools=self.tools,
            memory=self.memory,
            verbose=True
        )

    def chat(self, message: str) -> str:
        """Chat with agent (maintains conversation history)"""
        result = self.agent_executor.invoke({"input": message})
        return result["output"]

# ============================================
# AGENT WITH APPROVAL GATES
# ============================================

class SafeNetworkAgent:
    """Agent with human approval for risky actions"""

    def __init__(self):
        self.approval_log = []

    def requires_approval(self, action: Dict) -> bool:
        """Check if action requires human approval"""

        high_risk_tools = ["apply_config", "reload_device", "clear_bgp"]
        return action.get("tool") in high_risk_tools

    def request_approval(self, action: Dict) -> bool:
        """Request human approval for action"""

        print(f"\\n⚠️  APPROVAL REQUIRED ⚠️")
        print(f"Action: {action['tool']}")
        print(f"Parameters: {json.dumps(action.get('parameters', {}), indent=2)}")
        print(f"Reason: {action.get('thought')}")

        # In production, integrate with ticketing system
        # For demo, simulate approval
        approval = input("\\nApprove this action? (yes/no): ")

        approved = approval.lower() == "yes"

        # Log approval decision
        self.approval_log.append({
            "action": action,
            "approved": approved,
            "timestamp": "2024-02-05T10:30:00Z"
        })

        return approved

    def execute_with_approval(self, action: Dict) -> str:
        """Execute action with approval check"""

        if self.requires_approval(action):
            if not self.request_approval(action):
                return "Action rejected by human operator"

        # Execute action
        return "Action executed successfully"

