from openai import OpenAI
from anthropic import Anthropic
import time
import json
import os

# Initialize clients
openai_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
anthropic_client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))


class ModelBenchmark:
    """Benchmark different models on networking tasks"""

    def __init__(self):
        self.results = []

    def test_openai_model(self, model, prompt, temperature=0.3):
        """Test an OpenAI model"""
        start_time = time.time()

        try:
            response = openai_client.chat.completions.create(
                model=model,
                temperature=temperature,
                messages=[{"role": "user", "content": prompt}]
            )

            elapsed = time.time() - start_time

            return {
                "model": model,
                "provider": "openai",
                "response": response.choices[0].message.content,
                "time": elapsed,
                "input_tokens": response.usage.prompt_tokens,
                "output_tokens": response.usage.completion_tokens,
                "total_tokens": response.usage.total_tokens,
                "error": None
            }

        except Exception as e:
            return {
                "model": model,
                "provider": "openai",
                "error": str(e),
                "time": time.time() - start_time
            }

    def test_anthropic_model(self, model, prompt, temperature=0.3):
        """Test an Anthropic model"""
        start_time = time.time()

        try:
            response = anthropic_client.messages.create(
                model=model,
                max_tokens=2000,
                temperature=temperature,
                messages=[{"role": "user", "content": prompt}]
            )

            elapsed = time.time() - start_time

            return {
                "model": model,
                "provider": "anthropic",
                "response": response.content[0].text,
                "time": elapsed,
                "input_tokens": response.usage.input_tokens,
                "output_tokens": response.usage.output_tokens,
                "total_tokens": response.usage.input_tokens + response.usage.output_tokens,
                "error": None
            }

        except Exception as e:
            return {
                "model": model,
                "provider": "anthropic",
                "error": str(e),
                "time": time.time() - start_time
            }

    def benchmark_task(self, task_name, prompt, models):
        """Benchmark multiple models on a task"""
        print(f"\n{'='*70}")
        print(f"Benchmarking: {task_name}")
        print(f"{'='*70}\n")

        results = []

        for model_info in models:
            provider = model_info["provider"]
            model = model_info["model"]

            print(f"Testing {model}...", end=" ")

            if provider == "openai":
                result = self.test_openai_model(model, prompt)
            else:
                result = self.test_anthropic_model(model, prompt)

            results.append(result)

            if result["error"]:
                print(f"❌ Error: {result['error']}")
            else:
                print(f"✅ {result['time']:.2f}s | {result['total_tokens']} tokens")

        self.results.append({
            "task": task_name,
            "results": results
        })

        return results

    def calculate_costs(self, result):
        """Calculate cost for a result"""
        pricing = {
            "gpt-4": {"input": 30.00, "output": 60.00},
            "gpt-4o": {"input": 5.00, "output": 15.00},
            "gpt-4o-mini": {"input": 0.15, "output": 0.60},
            "claude-3-opus-20240229": {"input": 15.00, "output": 75.00},
            "claude-3-5-sonnet-20241022": {"input": 3.00, "output": 15.00},
            "claude-3-haiku-20240307": {"input": 0.25, "output": 1.25}
        }

        if result["error"]:
            return 0.0

        prices = pricing.get(result["model"], {"input": 0, "output": 0})

        input_cost = (result["input_tokens"] / 1_000_000) * prices["input"]
        output_cost = (result["output_tokens"] / 1_000_000) * prices["output"]

        return input_cost + output_cost

    def print_comparison(self):
        """Print comparison table"""
        for task_data in self.results:
            print(f"\n{'='*70}")
            print(f"Task: {task_data['task']}")
            print(f"{'='*70}")
            print(f"{'Model':<30} {'Time':<10} {'Tokens':<10} {'Cost':<10}")
            print("-"*70)

            for result in task_data['results']:
                if not result["error"]:
                    cost = self.calculate_costs(result)
                    print(f"{result['model']:<30} {result['time']:<10.2f} {result['total_tokens']:<10} \${cost:<10.4f}")
                else:
                    print(f"{result['model']:<30} ERROR: {result['error']}")


# Example benchmarking session
benchmark = ModelBenchmark()

# Task 1: Security Analysis
security_prompt = """Analyze this firewall ACL for security issues:

access-list 101 permit ip any any
access-list 102 permit tcp any any eq 22
access-list 102 permit tcp any any eq 23
access-list 102 deny ip any any log

List security concerns with severity levels."""

models_to_test = [
    {"provider": "openai", "model": "gpt-4o-mini"},
    {"provider": "openai", "model": "gpt-4o"},
    {"provider": "anthropic", "model": "claude-3-haiku-20240307"},
    {"provider": "anthropic", "model": "claude-3-5-sonnet-20241022"}
]

benchmark.benchmark_task("Security Analysis", security_prompt, models_to_test)

# Task 2: Configuration Generation
config_prompt = """Generate a basic OSPF configuration for:
- Router ID: 10.0.0.1
- Area 0
- Networks: 10.0.1.0/24, 10.0.2.0/24
- Interface: GigabitEthernet0/0

Provide only Cisco IOS commands."""

benchmark.benchmark_task("Config Generation", config_prompt, models_to_test)

# Print comparison
benchmark.print_comparison()

# Recommendation based on results
print("\n" + "="*70)
print("RECOMMENDATIONS")
print("="*70)
print("""
Based on benchmark results:

1. For simple tasks (log classification, basic queries):
   → Use GPT-4o-mini (fastest, cheapest)

2. For standard security analysis:
   → Use Claude 3.5 Sonnet (best accuracy)

3. For config generation:
   → Use GPT-4o (good balance of speed and quality)

4. For complex troubleshooting:
   → Use Claude 3.5 Sonnet (superior reasoning)

5. For high-volume operations:
   → Use 80/15/5 routing strategy to optimize costs
""")
