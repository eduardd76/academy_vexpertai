import os
from typing import List, Dict, Any, Optional
from openai import OpenAI
from anthropic import Anthropic
from langchain.agents import create_openai_tools_agent, AgentExecutor
from langchain.tools import tool
from langchain_openai import ChatOpenAI
from langchain.memory import ConversationBufferMemory
from langchain import hub
import json

# Initialize clients
openai_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
anthropic_client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

# ============================================
# SIMPLE AGENT FROM SCRATCH
# ============================================

class SimpleNetworkAgent:
    """Basic network agent implementation"""

    def __init__(self):
        self.memory = []
        self.max_iterations = 10

    def execute_tool(self, tool_name: str, parameters: Dict) -> str:
        """Execute a tool and return results"""

        if tool_name == "show_command":
            return self._execute_show_command(
                parameters.get("device"),
                parameters.get("command")
            )
        elif tool_name == "search_docs":
            return self._search_documentation(parameters.get("query"))
        elif tool_name == "check_logs":
            return self._check_logs(
                parameters.get("device"),
                parameters.get("hours", 1)
            )
        else:
            return f"Unknown tool: {tool_name}"

    def _execute_show_command(self, device: str, command: str) -> str:
        """Simulate executing show command"""
        # In production, use Netmiko
        outputs = {
            ("RTR-01", "show ip bgp summary"): """
BGP router identifier 10.0.0.1
Neighbor        V    AS MsgRcvd MsgSent   TblVer  InQ OutQ Up/Down  State
10.1.1.2        4 65002    1234    1235      100    0    0 5d04h    Established
10.1.1.3        4 65003    5678    5679      100    0    0 2d12h    Established
            """,
            ("SW-01", "show vlan brief"): """
VLAN Name                             Status    Ports
---- -------------------------------- --------- -------------------------------
1    default                          active    Gi0/3, Gi0/4
10   USERS                            active    Gi0/5, Gi0/6
20   SERVERS                          active    Gi0/7, Gi0/8
            """
        }
        return outputs.get((device, command), f"No output for {command} on {device}")

    def _search_documentation(self, query: str) -> str:
        """Simulate documentation search"""
        return f"Documentation results for: {query}\\n- BGP troubleshooting guide\\n- Common BGP issues"

    def _check_logs(self, device: str, hours: int) -> str:
        """Simulate log checking"""
        return f"Recent logs for {device} (last {hours}h):\\n- No errors found\\n- Normal operation"

    def think(self, task: str, context: List[Dict]) -> Dict:
        """Agent thinks about next action"""

        # Build prompt with context
        prompt = f"""You are a network troubleshooting agent.

Task: {task}

Previous actions:
{json.dumps(context, indent=2) if context else "None"}

Available tools:
- show_command: Execute show command on device
- search_docs: Search documentation
- check_logs: Check device logs

Decide your next action. Respond with JSON:
{{
    "thought": "Why I'm taking this action",
    "tool": "tool_name",
    "parameters": {{}},
    "is_final": false
}}

If task is complete, set "is_final": true and include "answer" field."""

        response = anthropic_client.messages.create(
            model="claude-3-5-sonnet-20241022",
            max_tokens=1000,
            messages=[{"role": "user", "content": prompt}]
        )

        # Parse response
        try:
            action = json.loads(response.content[0].text)
        except:
            # Fallback if JSON parsing fails
            action = {
                "thought": "Parsing error",
                "tool": "FINISH",
                "is_final": True
            }

        return action

    def run(self, task: str) -> str:
        """Run agent on task"""

        print(f"🤖 Agent starting task: {task}\\n")
        context = []

        for iteration in range(self.max_iterations):
            # Think about next action
            action = self.think(task, context)

            print(f"💭 Iteration {iteration + 1}")
            print(f"   Thought: {action.get('thought')}")
            print(f"   Tool: {action.get('tool')}")

            # Check if done
            if action.get("is_final"):
                final_answer = action.get("answer", "Task completed")
                print(f"\\n✅ Final Answer: {final_answer}")
                return final_answer

            # Execute tool
            if action.get("tool") != "FINISH":
                result = self.execute_tool(
                    action["tool"],
                    action.get("parameters", {})
                )
                print(f"   Result: {result[:100]}...")

                # Add to context
                context.append({
                    "action": action["tool"],
                    "parameters": action.get("parameters"),
                    "result": result
                })

        return "Max iterations reached"

# ============================================
# LANGCHAIN AGENT IMPLEMENTATION
# ============================================

# Define tools for LangChain
@tool
def execute_show_command(device: str, command: str) -> str:
    """Execute show command on network device.

    Args:
        device: Device hostname or IP address
        command: Show command to execute (e.g., 'show ip bgp summary')
    """
    # Simulate command execution
    if "bgp" in command.lower():
        return """BGP router identifier 10.0.0.1
Neighbor        V    AS MsgRcvd MsgSent   TblVer  InQ OutQ Up/Down  State
10.1.1.2        4 65002    1234    1235      100    0    0 5d04h    Established"""
    elif "interface" in command.lower():
        return """GigabitEthernet0/1 is up, line protocol is up
  Hardware is iGbE, address is 0011.2233.4455
  MTU 1500 bytes, BW 1000000 Kbit/sec"""
    else:
        return f"Output for {command} on {device}"

@tool
def search_documentation(query: str) -> str:
    """Search network documentation for information.

    Args:
        query: Search query string
    """
    # Simulate documentation search (integrate RAG from Chapter 14)
    return f"""Documentation results for '{query}':
1. BGP Troubleshooting Guide - Common issues and solutions
2. Interface Status Interpretation - Understanding show output
3. Best Practices - Network configuration standards"""

@tool
def check_device_logs(device: str, hours: int = 1) -> str:
    """Check syslog entries for a device.

    Args:
        device: Device hostname
        hours: Number of hours to look back (default 1)
    """
    return f"""Logs for {device} (last {hours}h):
2024-02-05 10:23:15 %BGP-5-ADJCHANGE: neighbor 10.1.1.2 Up
2024-02-05 09:45:32 %SYS-5-CONFIG_I: Configured from console"""

class LangChainNetworkAgent:
    """Network agent using LangChain framework"""

    def __init__(self, model: str = "gpt-4"):
        self.llm = ChatOpenAI(model=model, temperature=0)
        self.tools = [
            execute_show_command,
            search_documentation,
            check_device_logs
        ]

        # Create agent prompt
        self.prompt = hub.pull("hwchase17/openai-tools-agent")

        # Create agent
        self.agent = create_openai_tools_agent(
            self.llm,
            self.tools,
            self.prompt
        )

        # Create executor
        self.agent_executor = AgentExecutor(
            agent=self.agent,
            tools=self.tools,
            verbose=True,
            max_iterations=10
        )

    def run(self, task: str) -> str:
        """Execute task with agent"""
        result = self.agent_executor.invoke({"input": task})
        return result["output"]

