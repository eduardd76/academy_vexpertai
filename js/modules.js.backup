import os
import hashlib
import json
import re
from datetime import datetime, timedelta
from typing import Dict, List, Optional, Tuple
import tiktoken
from anthropic import Anthropic
from openai import OpenAI

# Initialize clients
anthropic_client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))
openai_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

# ============================================
# STRATEGY 1: TOKEN MINIMIZATION
# ============================================

class TokenMinimizer:
    """Analyze and optimize prompts to reduce token usage"""

    def __init__(self):
        self.encoding = tiktoken.get_encoding("cl100k_base")

        # Patterns to remove
        self.wasteful_patterns = [
            (r'\\bplease\\b', ''),
            (r'\\bthank you\\b', ''),
            (r'\\bI would like you to\\b', ''),
            (r'\\bCould you\\b', ''),
            (r'\\bbasically\\b', ''),
            (r'\\bessentially\\b', ''),
            (r'\\bactually\\b', ''),
            (r'\\s+', ' '),  # Multiple spaces
        ]

    def count_tokens(self, text: str) -> int:
        """Count tokens in text"""
        return len(self.encoding.encode(text))

    def optimize(self, prompt: str) -> Tuple[str, Dict]:
        """
        Optimize prompt by removing wasteful tokens.

        Returns:
            Tuple of (optimized_prompt, statistics)
        """
        original_tokens = self.count_tokens(prompt)
        optimized = prompt

        # Apply optimization patterns
        for pattern, replacement in self.wasteful_patterns:
            optimized = re.sub(pattern, replacement, optimized, flags=re.IGNORECASE)

        # Remove extra whitespace
        optimized = ' '.join(optimized.split())

        # Calculate savings
        new_tokens = self.count_tokens(optimized)
        tokens_saved = original_tokens - new_tokens
        percent_saved = (tokens_saved / original_tokens * 100) if original_tokens > 0 else 0

        stats = {
            'original_tokens': original_tokens,
            'optimized_tokens': new_tokens,
            'tokens_saved': tokens_saved,
            'percent_saved': percent_saved,
            'original_prompt': prompt,
            'optimized_prompt': optimized
        }

        return optimized, stats

    def analyze_prompt(self, prompt: str) -> Dict:
        """Analyze prompt for optimization opportunities"""
        issues = []

        # Check for politeness
        if re.search(r'\\b(please|thank you|thanks)\\b', prompt, re.IGNORECASE):
            issues.append("Contains unnecessary politeness words")

        # Check for verbose phrases
        verbose_phrases = [
            "I would like you to",
            "Could you please",
            "If you don't mind",
            "Would you be able to"
        ]
        for phrase in verbose_phrases:
            if phrase.lower() in prompt.lower():
                issues.append(f"Contains verbose phrase: '{phrase}'")

        # Check for filler words
        filler_words = ["basically", "essentially", "actually", "literally"]
        for word in filler_words:
            if word in prompt.lower():
                issues.append(f"Contains filler word: '{word}'")

        # Check for redundant spacing
        if re.search(r'\\s{2,}', prompt):
            issues.append("Contains extra whitespace")

        return {
            'issues_found': len(issues),
            'issues': issues,
            'potential_savings': len(issues) * 5  # Rough estimate
        }


# ============================================
# STRATEGY 2: INTELLIGENT MODEL ROUTING
# ============================================

class ModelRouter:
    """Route requests to appropriate models based on complexity"""

    def __init__(self):
        self.models = {
            'cheap': {
                'anthropic': 'claude-3-haiku-20240307',
                'openai': 'gpt-4o-mini',
                'cost_input': 0.25,  # per million tokens
                'cost_output': 1.25
            },
            'mid': {
                'anthropic': 'claude-3-5-sonnet-20241022',
                'openai': 'gpt-4o',
                'cost_input': 3.00,
                'cost_output': 15.00
            },
            'premium': {
                'anthropic': 'claude-3-opus-20240229',
                'openai': 'o1-preview',
                'cost_input': 15.00,
                'cost_output': 75.00
            }
        }

    def estimate_complexity(self, prompt: str, config_size: int = 0) -> int:
        """
        Estimate task complexity (1-10 scale).

        Args:
            prompt: Task description
            config_size: Size of configuration (lines or tokens)

        Returns:
            Complexity score (1-10)
        """
        complexity = 0
        prompt_lower = prompt.lower()

        # Simple keyword classification
        if any(word in prompt_lower for word in ['classify', 'categorize', 'tag']):
            complexity += 2

        # Analysis tasks
        if any(word in prompt_lower for word in ['analyze', 'review', 'audit', 'check']):
            complexity += 5

        # Complex reasoning
        if any(word in prompt_lower for word in ['troubleshoot', 'debug', 'diagnose', 'root cause']):
            complexity += 7

        # Generation tasks
        if any(word in prompt_lower for word in ['generate', 'create', 'write', 'design']):
            complexity += 6

        # Adjust for config size
        if config_size > 10000:
            complexity += 2
        elif config_size > 5000:
            complexity += 1

        return min(complexity, 10)

    def route_request(self, prompt: str, config_size: int = 0,
                     provider: str = 'anthropic') -> Dict:
        """
        Route request to appropriate model.

        Returns:
            Dictionary with model name and pricing info
        """
        complexity = self.estimate_complexity(prompt, config_size)

        # Route based on complexity
        if complexity <= 3:
            tier = 'cheap'
        elif complexity <= 7:
            tier = 'mid'
        else:
            tier = 'premium'

        model_info = self.models[tier].copy()
        model_info['tier'] = tier
        model_info['complexity'] = complexity
        model_info['model'] = model_info[provider]

        return model_info

    def calculate_cost_savings(self, requests: List[Dict]) -> Dict:
        """
        Calculate savings from intelligent routing vs using premium for all.

        Args:
            requests: List of {prompt, config_size} dictionaries

        Returns:
            Cost comparison statistics
        """
        total_premium_cost = 0
        total_routed_cost = 0

        for req in requests:
            # Premium model cost (baseline)
            premium_cost = (1000 * 15.00 + 500 * 75.00) / 1_000_000  # Assumed tokens
            total_premium_cost += premium_cost

            # Routed model cost
            route = self.route_request(req['prompt'], req.get('config_size', 0))
            routed_cost = (1000 * route['cost_input'] + 500 * route['cost_output']) / 1_000_000
            total_routed_cost += routed_cost

        return {
            'total_requests': len(requests),
            'premium_only_cost': total_premium_cost,
            'routed_cost': total_routed_cost,
            'savings': total_premium_cost - total_routed_cost,
            'savings_percent': ((total_premium_cost - total_routed_cost) / total_premium_cost * 100)
        }


# ============================================
# STRATEGY 3: BATCH PROCESSING
# ============================================

class BatchProcessor:
    """Combine multiple requests into batches for efficiency"""

    def __init__(self, max_batch_size: int = 10, max_tokens: int = 150000):
        self.max_batch_size = max_batch_size
        self.max_tokens = max_tokens
        self.encoding = tiktoken.get_encoding("cl100k_base")

    def count_tokens(self, text: str) -> int:
        """Count tokens in text"""
        return len(self.encoding.encode(text))

    def create_batches(self, items: List[Dict]) -> List[List[Dict]]:
        """
        Group items into optimal batches.

        Args:
            items: List of {id, config, prompt} dictionaries

        Returns:
            List of batches (each batch is a list of items)
        """
        batches = []
        current_batch = []
        current_tokens = 0

        for item in items:
            item_tokens = self.count_tokens(item['config'])

            # Check if adding this item would exceed limits
            if (len(current_batch) >= self.max_batch_size or
                current_tokens + item_tokens > self.max_tokens):

                if current_batch:
                    batches.append(current_batch)
                    current_batch = []
                    current_tokens = 0

            current_batch.append(item)
            current_tokens += item_tokens

        # Add final batch
        if current_batch:
            batches.append(current_batch)

        return batches

    def create_batch_prompt(self, batch: List[Dict], task_description: str) -> str:
        """
        Create a single prompt for analyzing multiple configs.

        Args:
            batch: List of config items
            task_description: What to do with each config

        Returns:
            Combined prompt string
        """
        prompt = f"""{task_description}

Process each configuration and return results as a JSON array:

[
  {{
    "id": "<config_id>",
    "result": {{...}}
  }},
  ...
]

Configurations to analyze:

"""

        for item in batch:
            prompt += f"""
{'='*70}
Configuration ID: {item['id']}
{'='*70}
{item['config']}

"""

        return prompt

    def parse_batch_results(self, response: str) -> List[Dict]:
        """
        Parse JSON array response from batch processing.

        Args:
            response: LLM response containing JSON array

        Returns:
            List of individual results
        """
        # Extract JSON array
        json_match = re.search(r'\\[.*\\]', response, re.DOTALL)

        if json_match:
            try:
                results = json.loads(json_match.group())
                return results
            except json.JSONDecodeError:
                print("❌ Failed to parse batch results as JSON")
                return []
        else:
            print("❌ No JSON array found in response")
            return []


# ============================================
# STRATEGY 4: RESPONSE CACHING
# ============================================

class ResponseCache:
    """Cache API responses to avoid duplicate requests"""

    def __init__(self, ttl_hours: int = 24):
        self.cache = {}
        self.ttl = timedelta(hours=ttl_hours)
        self.hits = 0
        self.misses = 0

    def _generate_key(self, prompt: str, config: str) -> str:
        """Generate cache key from request parameters"""
        content = f"{prompt}::{config}"
        return hashlib.md5(content.encode()).hexdigest()

    def get(self, prompt: str, config: str) -> Optional[str]:
        """
        Retrieve cached response if available and not expired.

        Returns:
            Cached response or None
        """
        key = self._generate_key(prompt, config)

        if key in self.cache:
            entry = self.cache[key]

            # Check if expired
            if datetime.now() - entry['timestamp'] < self.ttl:
                self.hits += 1
                return entry['response']
            else:
                # Remove expired entry
                del self.cache[key]

        self.misses += 1
        return None

    def set(self, prompt: str, config: str, response: str):
        """Store response in cache"""
        key = self._generate_key(prompt, config)
        self.cache[key] = {
            'response': response,
            'timestamp': datetime.now()
        }

    def get_stats(self) -> Dict:
        """Get cache performance statistics"""
        total_requests = self.hits + self.misses
        hit_rate = (self.hits / total_requests * 100) if total_requests > 0 else 0

        return {
            'total_requests': total_requests,
            'cache_hits': self.hits,
            'cache_misses': self.misses,
            'hit_rate_percent': hit_rate,
            'cache_size': len(self.cache)
        }

    def clear_expired(self):
        """Remove all expired entries"""
        now = datetime.now()
        expired_keys = [
            key for key, entry in self.cache.items()
            if now - entry['timestamp'] >= self.ttl
        ]

        for key in expired_keys:
            del self.cache[key]

        return len(expired_keys)


# ============================================
# STRATEGY 5: COST MONITORING
# ============================================

class CostMonitor:
    """Track and monitor API costs"""

    def __init__(self, monthly_budget: float = 1000.0):
        self.monthly_budget = monthly_budget
        self.requests = []

        # Pricing (per million tokens)
        self.pricing = {
            'claude-3-haiku-20240307': {'input': 0.25, 'output': 1.25},
            'claude-3-5-sonnet-20241022': {'input': 3.00, 'output': 15.00},
            'claude-3-opus-20240229': {'input': 15.00, 'output': 75.00},
            'gpt-4o-mini': {'input': 0.15, 'output': 0.60},
            'gpt-4o': {'input': 2.50, 'output': 10.00}
        }

    def calculate_cost(self, model: str, input_tokens: int, output_tokens: int) -> float:
        """Calculate cost for a request"""
        if model not in self.pricing:
            print(f"⚠️ Unknown model: {model}, using default pricing")
            return 0.01

        prices = self.pricing[model]
        input_cost = (input_tokens * prices['input']) / 1_000_000
        output_cost = (output_tokens * prices['output']) / 1_000_000

        return input_cost + output_cost

    def track_request(self, model: str, input_tokens: int, output_tokens: int,
                     user: str, request_type: str, cached: bool = False):
        """Track a request and its cost"""
        cost = self.calculate_cost(model, input_tokens, output_tokens) if not cached else 0

        self.requests.append({
            'timestamp': datetime.now(),
            'model': model,
            'input_tokens': input_tokens,
            'output_tokens': output_tokens,
            'cost': cost,
            'user': user,
            'request_type': request_type,
            'cached': cached
        })

    def get_monthly_total(self) -> float:
        """Calculate total cost for current month"""
        now = datetime.now()
        month_start = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)

        monthly_requests = [
            r for r in self.requests
            if r['timestamp'] >= month_start
        ]

        return sum(r['cost'] for r in monthly_requests)

    def get_statistics(self) -> Dict:
        """Get comprehensive cost statistics"""
        total_cost = sum(r['cost'] for r in self.requests)
        monthly_cost = self.get_monthly_total()

        # Group by model
        by_model = {}
        for req in self.requests:
            model = req['model']
            if model not in by_model:
                by_model[model] = {'requests': 0, 'cost': 0}
            by_model[model]['requests'] += 1
            by_model[model]['cost'] += req['cost']

        # Group by user
        by_user = {}
        for req in self.requests:
            user = req['user']
            if user not in by_user:
                by_user[user] = {'requests': 0, 'cost': 0}
            by_user[user]['requests'] += 1
            by_user[user]['cost'] += req['cost']

        # Cache statistics
        total_requests = len(self.requests)
        cached_requests = sum(1 for r in self.requests if r.get('cached', False))
        cache_rate = (cached_requests / total_requests * 100) if total_requests > 0 else 0

        return {
            'total_requests': total_requests,
            'total_cost': total_cost,
            'monthly_cost': monthly_cost,
            'monthly_budget': self.monthly_budget,
            'budget_used_percent': (monthly_cost / self.monthly_budget * 100),
            'by_model': by_model,
            'by_user': by_user,
            'cached_requests': cached_requests,
            'cache_rate_percent': cache_rate
        }

    def check_budget_alert(self) -> Optional[str]:
        """Check if budget thresholds are exceeded"""
        monthly_cost = self.get_monthly_total()
        percent_used = (monthly_cost / self.monthly_budget * 100)

        if percent_used >= 100:
            return f"🚨 CRITICAL: Budget exceeded! \${monthly_cost:.2f} / \${self.monthly_budget:.2f}"
        elif percent_used >= 85:
            return f"⚠️ WARNING: 85% of budget used (\${monthly_cost:.2f} / \${self.monthly_budget:.2f})"
        elif percent_used >= 70:
            return f"ℹ️ NOTICE: 70% of budget used (\${monthly_cost:.2f} / \${self.monthly_budget:.2f})"

        return None


# ============================================
# INTEGRATED SYSTEM
# ============================================

class OptimizedAISystem:
    """Complete cost-optimized AI system integrating all strategies"""

    def __init__(self, monthly_budget: float = 1000.0):
        self.token_minimizer = TokenMinimizer()
        self.model_router = ModelRouter()
        self.batch_processor = BatchProcessor()
        self.response_cache = ResponseCache()
        self.cost_monitor = CostMonitor(monthly_budget)
        self.anthropic_client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))

    def process_request(self, prompt: str, config: str, user: str,
                       request_type: str) -> Dict:
        """
        Process a request with all optimization strategies.

        Returns:
            Response and statistics
        """
        # Step 1: Check cache
        cached_response = self.response_cache.get(prompt, config)
        if cached_response:
            print("✅ Cache hit - returning cached response")
            self.cost_monitor.track_request(
                'cached', 0, 0, user, request_type, cached=True
            )
            return {
                'response': cached_response,
                'cached': True,
                'cost': 0
            }

        # Step 2: Minimize tokens
        optimized_prompt, opt_stats = self.token_minimizer.optimize(prompt)
        print(f"Token optimization: {opt_stats['original_tokens']} → "
              f"{opt_stats['optimized_tokens']} tokens "
              f"({opt_stats['percent_saved']:.1f}% saved)")

        # Step 3: Route to appropriate model
        route_info = self.model_router.route_request(optimized_prompt, len(config))
        print(f"Model routing: Complexity {route_info['complexity']} → "
              f"{route_info['tier']} tier ({route_info['model']})")

        # Step 4: Make API call
        try:
            response = self.anthropic_client.messages.create(
                model=route_info['model'],
                max_tokens=2000,
                temperature=0,
                messages=[{
                    "role": "user",
                    "content": f"{optimized_prompt}\\n\\n{config}"
                }]
            )

            response_text = response.content[0].text

            # Step 5: Cache response
            self.response_cache.set(prompt, config, response_text)

            # Step 6: Track costs
            cost = self.cost_monitor.calculate_cost(
                route_info['model'],
                response.usage.input_tokens,
                response.usage.output_tokens
            )

            self.cost_monitor.track_request(
                route_info['model'],
                response.usage.input_tokens,
                response.usage.output_tokens,
                user,
                request_type,
                cached=False
            )

            print(f"Cost: \${cost:.6f}")

            # Check budget
            alert = self.cost_monitor.check_budget_alert()
            if alert:
                print(alert)

            return {
                'response': response_text,
                'cached': False,
                'cost': cost,
                'model': route_info['model'],
                'tokens': {
                    'input': response.usage.input_tokens,
                    'output': response.usage.output_tokens
                }
            }

        except Exception as e:
            print(f"❌ Error processing request: {e}")
            return {'error': str(e)}

    def get_dashboard(self) -> Dict:
        """Generate cost optimization dashboard"""
        cost_stats = self.cost_monitor.get_statistics()
        cache_stats = self.response_cache.get_stats()

        return {
            'cost_statistics': cost_stats,
            'cache_statistics': cache_stats,
            'budget_alert': self.cost_monitor.check_budget_alert()
        }


# ============================================
# EXAMPLE USAGE
# ============================================

