        code: `# Chapter 16: Document Retrieval - Complete Implementation

!pip install langchain chromadb openai sentence-transformers rank-bm25

import os
from typing import List, Dict, Tuple
from openai import OpenAI
import chromadb
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain.embeddings import OpenAIEmbeddings
from langchain.vectorstores import Chroma
from langchain.docstore.document import Document
from sentence_transformers import CrossEncoder
from rank_bm25 import BM25Okapi
import numpy as np
from functools import lru_cache

client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

# ============================================
# ADVANCED CHUNKING
# ============================================

class SemanticChunker:
    """Chunk documents by semantic sections"""

    def chunk_network_config(self, config: str, device: str) -> List[Document]:
        """Chunk config by sections (VLANs, interfaces, routing)"""

        sections = {
            "vlans": self._extract_section(config, ["vlan"]),
            "interfaces": self._extract_section(config, ["interface"]),
            "routing": self._extract_section(config, ["router bgp", "router ospf", "router eigrp"]),
            "acls": self._extract_section(config, ["access-list", "ip access-list"]),
            "other": ""
        }

        documents = []

        for section_name, content in sections.items():
            if content.strip():
                doc = Document(
                    page_content=content,
                    metadata={
                        "device": device,
                        "section": section_name,
                        "char_count": len(content)
                    }
                )
                documents.append(doc)

        return documents

    def _extract_section(self, config: str, keywords: List[str]) -> str:
        """Extract lines matching keywords"""
        lines = config.split("\\n")
        section_lines = []
        in_section = False

        for line in lines:
            if any(kw in line.lower() for kw in keywords):
                in_section = True
            elif in_section and line and not line.startswith(" "):
                in_section = False

            if in_section:
                section_lines.append(line)

        return "\\n".join(section_lines)

# ============================================
# HYBRID SEARCH
# ============================================

class HybridRetriever:
    """Combine vector and keyword search"""

    def __init__(self, vectorstore, documents: List[str]):
        self.vectorstore = vectorstore
        self.documents = documents

        # Build BM25 index for keyword search
        tokenized_docs = [doc.lower().split() for doc in documents]
        self.bm25 = BM25Okapi(tokenized_docs)

    def retrieve(self, query: str, k: int = 5, alpha: float = 0.7) -> List[Dict]:
        """
        Hybrid retrieval with weighted combination

        Args:
            query: Search query
            k: Number of results
            alpha: Weight for vector search (1-alpha for keyword)
        """

        # Vector search
        vector_results = self.vectorstore.similarity_search_with_score(query, k=k*2)

        # Normalize vector scores (0-1)
        max_vector_score = max([score for _, score in vector_results]) if vector_results else 1
        vector_scores = {
            doc.page_content: 1 - (score / max_vector_score)
            for doc, score in vector_results
        }

        # Keyword search (BM25)
        tokenized_query = query.lower().split()
        bm25_scores = self.bm25.get_scores(tokenized_query)

        # Normalize BM25 scores
        max_bm25 = max(bm25_scores) if max(bm25_scores) > 0 else 1
        keyword_scores = {
            self.documents[i]: bm25_scores[i] / max_bm25
            for i in range(len(self.documents))
        }

        # Combine scores
        combined_scores = {}
        all_docs = set(vector_scores.keys()) | set(keyword_scores.keys())

        for doc in all_docs:
            v_score = vector_scores.get(doc, 0)
            k_score = keyword_scores.get(doc, 0)
            combined_scores[doc] = alpha * v_score + (1 - alpha) * k_score

        # Sort by combined score
        sorted_docs = sorted(
            combined_scores.items(),
            key=lambda x: x[1],
            reverse=True
        )[:k]

        return [
            {"document": doc, "score": score}
            for doc, score in sorted_docs
        ]

# ============================================
# RERANKING
# ============================================

class Reranker:
    """Rerank results using cross-encoder"""

    def __init__(self, model_name: str = "cross-encoder/ms-marco-MiniLM-L-6-v2"):
        self.model = CrossEncoder(model_name)

    def rerank(self, query: str, documents: List[str], top_k: int = 5) -> List[Tuple[str, float]]:
        """
        Rerank documents using cross-encoder

        Args:
            query: Search query
            documents: List of candidate documents
            top_k: Number of top results to return

        Returns:
            List of (document, score) tuples
        """

        # Create query-document pairs
        pairs = [[query, doc] for doc in documents]

        # Score all pairs
        scores = self.model.predict(pairs)

        # Sort by score
        doc_scores = list(zip(documents, scores))
        doc_scores.sort(key=lambda x: x[1], reverse=True)

        return doc_scores[:top_k]

# ============================================
# PRODUCTION RETRIEVAL SYSTEM
# ============================================

class ProductionRetriever:
    """Production-ready retrieval system"""

    def __init__(self, vectorstore, documents: List[str]):
        self.vectorstore = vectorstore
        self.hybrid_retriever = HybridRetriever(vectorstore, documents)
        self.reranker = Reranker()
        self.query_cache = {}

    @lru_cache(maxsize=1000)
    def retrieve_cached(self, query: str, k: int = 5) -> str:
        """Cached retrieval for common queries"""
        return str(self.retrieve(query, k))

    def retrieve(self, query: str, k: int = 5, use_reranking: bool = True) -> List[Dict]:
        """
        Complete retrieval pipeline

        Args:
            query: Search query
            k: Number of final results
            use_reranking: Whether to apply reranking

        Returns:
            List of retrieved documents with scores
        """

        # Step 1: Query expansion
        expanded_query = self._expand_query(query)

        # Step 2: Hybrid retrieval (get more candidates)
        candidates = self.hybrid_retriever.retrieve(
            expanded_query,
            k=k*3 if use_reranking else k
        )

        # Step 3: Reranking (optional)
        if use_reranking and len(candidates) > k:
            candidate_docs = [c["document"] for c in candidates]
            reranked = self.reranker.rerank(query, candidate_docs, top_k=k)

            results = [
                {
                    "document": doc,
                    "score": float(score),
                    "reranked": True
                }
                for doc, score in reranked
            ]
        else:
            results = candidates[:k]

        return results

    def _expand_query(self, query: str) -> str:
        """Simple query expansion"""

        expansions = {
            "bgp": "bgp border gateway protocol neighbor peer",
            "ospf": "ospf open shortest path first area neighbor",
            "down": "down failed inactive not working error",
            "config": "configuration setting setup"
        }

        words = query.lower().split()
        expanded_words = []

        for word in words:
            expanded_words.append(word)
            if word in expansions:
                expanded_words.extend(expansions[word].split())

        return " ".join(expanded_words)

    def batch_retrieve(self, queries: List[str], k: int = 5) -> List[List[Dict]]:
        """Batch retrieval for multiple queries"""

        # Process all queries
        results = [self.retrieve(query, k) for query in queries]

        return results

# ============================================
# RETRIEVAL EVALUATION
# ============================================

class RetrievalEvaluator:
    """Evaluate retrieval quality"""

    def evaluate(self, retriever, test_cases: List[Dict]) -> Dict:
        """
        Evaluate retriever on test cases

        Args:
            retriever: Retriever to test
            test_cases: List of {"query": str, "relevant_docs": List[str]}

        Returns:
            Evaluation metrics
        """

        metrics = {
            "recall@5": [],
            "precision@5": [],
            "mrr": []
        }

        for test in test_cases:
            query = test["query"]
            relevant_docs = set(test["relevant_docs"])

            # Retrieve
            results = retriever.retrieve(query, k=5)
            retrieved_docs = set([r["document"][:50] for r in results])  # First 50 chars

            # Calculate metrics
            relevant_retrieved = retrieved_docs & relevant_docs

            # Recall@5
            recall = len(relevant_retrieved) / len(relevant_docs) if relevant_docs else 0
            metrics["recall@5"].append(recall)

            # Precision@5
            precision = len(relevant_retrieved) / len(retrieved_docs) if retrieved_docs else 0
            metrics["precision@5"].append(precision)

            # MRR (Mean Reciprocal Rank)
            for i, doc in enumerate([r["document"][:50] for r in results], 1):
                if doc in relevant_docs:
                    metrics["mrr"].append(1.0 / i)
                    break
            else:
                metrics["mrr"].append(0.0)

        # Average metrics
        return {
            "recall@5": np.mean(metrics["recall@5"]),
            "precision@5": np.mean(metrics["precision@5"]),
            "mrr": np.mean(metrics["mrr"])
        }

# ============================================
# EXAMPLE USAGE
# ============================================

# Sample documents
sample_docs = [
    "RTR-01 BGP configuration: router bgp 65001, neighbor 10.1.1.2 remote-as 65002",
    "SW-01 VLAN configuration: vlan 10 name USERS, vlan 20 name SERVERS",
    "RTR-02 OSPF configuration: router ospf 1, network 10.0.0.0 0.255.255.255 area 0"
]

# Create embeddings and vectorstore
embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
docs = [Document(page_content=doc) for doc in sample_docs]
vectorstore = Chroma.from_documents(docs, embeddings)

# Initialize production retriever
prod_retriever = ProductionRetriever(vectorstore, sample_docs)

# Retrieve with all optimizations
query = "BGP neighbor configuration"
results = prod_retriever.retrieve(query, k=3, use_reranking=True)

print("🔍 Production Retrieval Results:")
for i, result in enumerate(results, 1):
    print(f"\\n{i}. Score: {result['score']:.4f}")
    print(f"   {result['document'][:100]}...")

# Evaluate retrieval
evaluator = RetrievalEvaluator()
test_cases = [
    {
        "query": "BGP configuration",
        "relevant_docs": ["RTR-01 BGP configuration"]
    }
]

metrics = evaluator.evaluate(prod_retriever, test_cases)
print(f"\\n📊 Evaluation Metrics:")
print(f"   Recall@5: {metrics['recall@5']:.2%}")
print(f"   Precision@5: {metrics['precision@5']:.2%}")
print(f"   MRR: {metrics['mrr']:.4f}")

print("\\n✅ Chapter 16 Complete - Advanced Retrieval Ready!")
