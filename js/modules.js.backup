import json

def extract_json(text: str) -> dict:
    """Extract JSON from LLM response with markdown"""

    # Pattern 1: Markdown code block
    markdown_pattern = r'\`\`\`(?:json)?\s*(\{.*?\})\s*\`\`\`'
    match = re.search(markdown_pattern, text, re.DOTALL)
    if match:
        return json.loads(match.group(1))

    # Pattern 2: Raw JSON
    json_pattern = r'\{.*\}'
    match = re.search(json_pattern, text, re.DOTALL)
    if match:
        return json.loads(match.group(0))

    raise ValueError("No JSON found")

# Test cases
test_cases = [
    # Case 1: Markdown wrapped
    '''Here's the result:
    \`\`\`json
    {"hostname": "router1", "status": "up"}
    \`\`\`
    ''',

    # Case 2: Raw JSON
    '{"hostname": "router2", "status": "down"}',

    # Case 3: JSON in prose
    'The config shows {"hostname": "router3", "status": "up"} in production.'
]

for i, test in enumerate(test_cases, 1):
    try:
        result = extract_json(test)
        print(f"✅ Case {i}: {result}")
    except Exception as e:
        print(f"❌ Case {i}: {e}")`
