        code: `# Chapter 6 - Structured Outputs with Pydantic Validation

!pip install pydantic anthropic openai python-dotenv -q

import json
import re
from typing import List, Optional, Literal
from datetime import datetime
from pydantic import BaseModel, Field, validator, ValidationError
from ipaddress import IPv4Address, IPv4Network
from anthropic import Anthropic
import os

# Initialize client
client = Anthropic(api_key=os.getenv("ANTHROPIC_API_KEY"))


# Define Pydantic models for network data
class SecurityIssue(BaseModel):
    """Individual security issue with validation"""
    severity: Literal["CRITICAL", "HIGH", "MEDIUM", "LOW"]
    line_number: int = Field(ge=1, description="Line number in config")
    issue: str = Field(min_length=10, max_length=500)
    recommendation: str = Field(min_length=10, max_length=500)
    cve_reference: Optional[str] = None

    @validator('issue', 'recommendation')
    def not_empty(cls, v):
        """Ensure descriptions are not just whitespace"""
        if not v.strip():
            raise ValueError('Field cannot be empty')
        return v.strip()


class SecurityAnalysis(BaseModel):
    """Complete security analysis with validation"""
    hostname: str = Field(min_length=1, max_length=255)
    platform: str = Field(default="Cisco IOS")
    total_issues: int = Field(ge=0, description="Total number of issues found")
    critical_count: int = Field(ge=0)
    high_count: int = Field(ge=0)
    medium_count: int = Field(ge=0)
    low_count: int = Field(ge=0)
    issues: List[SecurityIssue] = Field(default_factory=list)
    scan_timestamp: str = Field(default_factory=lambda: datetime.now().isoformat())

    @validator('total_issues')
    def validate_total_matches(cls, v, values):
        """Ensure total_issues matches sum of severity counts"""
        expected_total = (
            values.get('critical_count', 0) +
            values.get('high_count', 0) +
            values.get('medium_count', 0) +
            values.get('low_count', 0)
        )
        if v != expected_total:
            raise ValueError(f'total_issues ({v}) must equal sum of counts ({expected_total})')
        return v


class InterfaceInfo(BaseModel):
    """Network interface with comprehensive validation"""
    interface: str = Field(min_length=1, max_length=50)
    ip_address: IPv4Address
    subnet_mask: IPv4Address
    status: Literal["up", "down", "admin-down"]
    description: Optional[str] = Field(None, max_length=255)
    vlan: Optional[int] = Field(None, ge=1, le=4094)
    speed: Optional[Literal["10", "100", "1000", "10000"]] = None
    duplex: Optional[Literal["auto", "half", "full"]] = None

    @validator('interface')
    def validate_interface_name(cls, v):
        """Validate Cisco interface naming convention"""
        valid_prefixes = [
            'GigabitEthernet', 'FastEthernet', 'Ethernet',
            'TenGigabitEthernet', 'Loopback', 'Vlan', 'Port-channel'
        ]
        if not any(v.startswith(prefix) for prefix in valid_prefixes):
            raise ValueError(f'Invalid interface name: {v}. Must start with {valid_prefixes}')
        return v

    @validator('subnet_mask')
    def validate_subnet_mask(cls, v):
        """Ensure subnet mask is valid"""
        # Convert to int and check if it's a valid subnet mask
        mask_int = int(v)
        # Valid subnet masks have contiguous 1s followed by contiguous 0s
        binary = bin(mask_int)[2:].zfill(32)
        if '01' in binary:  # 0 followed by 1 is invalid
            raise ValueError(f'Invalid subnet mask: {v}')
        return v


class BGPNeighbor(BaseModel):
    """BGP neighbor configuration with validation"""
    neighbor_ip: IPv4Address
    remote_as: int = Field(ge=1, le=4294967295, description="BGP AS number")
    description: Optional[str] = Field(None, max_length=200)
    update_source: Optional[str] = None
    ebgp_multihop: Optional[int] = Field(None, ge=1, le=255)
    password: Optional[str] = Field(None, max_length=100)
    state: Literal["Idle", "Connect", "Active", "OpenSent", "OpenConfirm", "Established"]
    prefixes_received: int = Field(ge=0)
    uptime: Optional[str] = None

    @validator('remote_as')
    def validate_as_number(cls, v):
        """Validate AS number is in valid range"""
        # Private AS: 64512-65534, 4200000000-4294967294
        # Public AS: Everything else in valid range
        if v == 0 or v == 23456:  # Reserved AS numbers
            raise ValueError(f'Reserved AS number: {v}')
        return v


def extract_json(text: str) -> str:
    """
    Extract JSON from LLM response, handling markdown formatting

    Args:
        text: Raw LLM response

    Returns:
        Extracted JSON string
    """
    # Try to extract from markdown code block
    markdown_pattern = r'\`\`\`(?:json)?\s*(\{.*?\})\s*\`\`\`'
    match = re.search(markdown_pattern, text, re.DOTALL)
    if match:
        return match.group(1)

    # Try to find raw JSON object
    json_pattern = r'\{.*\}'
    match = re.search(json_pattern, text, re.DOTALL)
    if match:
        return match.group(0)

    raise ValueError("No JSON found in response")


def validated_api_call(
    prompt: str,
    model_class: BaseModel,
    max_retries: int = 3,
    temperature: float = 0.0
) -> Optional[BaseModel]:
    """
    Make API call with automatic validation and retry logic

    Args:
        prompt: User prompt requesting JSON output
        model_class: Pydantic model for validation
        max_retries: Maximum retry attempts
        temperature: Sampling temperature (0.0 for deterministic)

    Returns:
        Validated Pydantic model instance or None if all retries fail
    """

    for attempt in range(max_retries):
        try:
            # Make API call
            response = client.messages.create(
                model="claude-3-5-sonnet-20241022",
                max_tokens=4000,
                temperature=temperature,
                messages=[{"role": "user", "content": prompt}]
            )

            # Extract and parse JSON
            response_text = response.content[0].text
            json_str = extract_json(response_text)
            json_data = json.loads(json_str)

            # Validate with Pydantic
            validated_data = model_class(**json_data)

            print(f"✅ Validation successful on attempt {attempt + 1}")
            return validated_data

        except json.JSONDecodeError as e:
            error_msg = f"Invalid JSON: {str(e)}"
            print(f"❌ Attempt {attempt + 1} failed: {error_msg}")

        except ValidationError as e:
            error_msg = f"Validation error: {e}"
            print(f"❌ Attempt {attempt + 1} failed: {error_msg}")

        except Exception as e:
            error_msg = f"Unexpected error: {str(e)}"
            print(f"❌ Attempt {attempt + 1} failed: {error_msg}")

        # Retry with error feedback
        if attempt < max_retries - 1:
            prompt += f"""

PREVIOUS RESPONSE HAD AN ERROR: {error_msg}

Please provide valid JSON matching the schema exactly. Ensure:
1. All required fields are present
2. Field types match the schema
3. Values are within valid ranges
4. No extra fields not in the schema"""

            print(f"Retrying with error feedback...\\n")

    print(f"❌ All {max_retries} attempts failed")
    return None


# Example 1: Security Analysis with Validation
def analyze_security_structured(config: str) -> Optional[SecurityAnalysis]:
    """Analyze configuration and return validated structured output"""

    prompt = f"""You are a network security expert. Analyze this configuration for security issues.

Configuration:
{config}

Respond with valid JSON matching this EXACT schema:

{{
  "hostname": "string (extract from config or use 'Unknown')",
  "platform": "string (e.g., 'Cisco IOS')",
  "total_issues": integer (total count),
  "critical_count": integer,
  "high_count": integer,
  "medium_count": integer,
  "low_count": integer,
  "issues": [
    {{
      "severity": "CRITICAL|HIGH|MEDIUM|LOW",
      "line_number": integer (>= 1),
      "issue": "string (10-500 chars)",
      "recommendation": "string (10-500 chars)",
      "cve_reference": "string or null"
    }}
  ],
  "scan_timestamp": "{datetime.now().isoformat()}"
}}

Important:
- total_issues MUST equal critical_count + high_count + medium_count + low_count
- severity must be exactly: CRITICAL, HIGH, MEDIUM, or LOW
- line_number must be >= 1
- Provide ONLY valid JSON, no additional text"""

    return validated_api_call(prompt, SecurityAnalysis)


# Example 2: Interface Parsing with Validation
def parse_interfaces_structured(show_output: str) -> Optional[List[InterfaceInfo]]:
    """Parse show interface output into validated structures"""

    prompt = f"""Parse this Cisco IOS interface output into structured JSON.

Output:
{show_output}

Respond with valid JSON array matching this schema:

[
  {{
    "interface": "string (e.g., 'GigabitEthernet0/0')",
    "ip_address": "IPv4 address string",
    "subnet_mask": "IPv4 subnet mask string",
    "status": "up|down|admin-down",
    "description": "string or null",
    "vlan": integer (1-4094) or null,
    "speed": "10|100|1000|10000" or null,
    "duplex": "auto|half|full" or null
  }}
]

Ensure:
- Interface names start with valid prefix (GigabitEthernet, FastEthernet, etc.)
- IP addresses are valid IPv4
- Subnet masks are valid (e.g., 255.255.255.0)
- Status is exactly: up, down, or admin-down
- VLAN is 1-4094 if present

Provide ONLY the JSON array, no markdown formatting."""

    class InterfaceList(BaseModel):
        interfaces: List[InterfaceInfo]

    result = validated_api_call(prompt, InterfaceList)
    return result.interfaces if result else None


