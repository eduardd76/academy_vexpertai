                title: 'Quick Prompt Optimizer',
                description: 'Remove wasteful tokens from prompts',
                code: `import re

def optimize_prompt(prompt: str) -> str:
    """Quick prompt optimization"""

    # Remove politeness
    prompt = re.sub(r'\\b(please|thank you|thanks)\\b', '', prompt, flags=re.IGNORECASE)

    # Remove verbose starters
    prompt = re.sub(r'\\bI would like you to\\b', '', prompt, flags=re.IGNORECASE)
    prompt = re.sub(r'\\bCould you\\b', '', prompt, flags=re.IGNORECASE)

    # Remove filler words
    fillers = ['basically', 'essentially', 'actually', 'literally']
    for word in fillers:
        prompt = re.sub(f'\\\\b{word}\\\\b', '', prompt, flags=re.IGNORECASE)

    # Clean up whitespace
    prompt = ' '.join(prompt.split())

    return prompt

# Test
original = "Could you please analyze this configuration and basically identify security issues"
optimized = optimize_prompt(original)

print(f"Original: {original}")
print(f"Optimized: {optimized}")
print(f"Savings: {len(original) - len(optimized)} characters")`
