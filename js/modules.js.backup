from datetime import datetime

class SimpleAuditLog:
    def __init__(self):
        self.conn = sqlite3.connect('audit.db')
        self.conn.execute('''
            CREATE TABLE IF NOT EXISTS ai_log (
                timestamp TEXT,
                user TEXT,
                operation TEXT,
                cost REAL
            )
        ''')

    def log(self, user, operation, cost):
        self.conn.execute(
            'INSERT INTO ai_log VALUES (?, ?, ?, ?)',
            (datetime.now().isoformat(), user, operation, cost)
        )
        self.conn.commit()

    def get_user_logs(self, user):
        cursor = self.conn.execute(
            'SELECT * FROM ai_log WHERE user = ?',
            (user,)
        )
        return cursor.fetchall()

# Usage
log = SimpleAuditLog()
log.log('john@company.com', 'config_analysis', 0.05)`
