    Returns:
        True if should retry, False otherwise
    """
    error_str = str(error).lower()

    # Transient errors - RETRY
    transient = [
        "rate_limit", "429",  # Rate limiting
        "500", "502", "503", "504",  # Server errors
        "timeout", "connection"  # Network issues
    ]

