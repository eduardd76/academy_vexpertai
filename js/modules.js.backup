                title: 'Simple Approval System',
                description: 'Require human approval for changes',
                code: `from datetime import datetime, timedelta

class SimpleApproval:
    def __init__(self):
        self.pending = {}

    def request(self, change_id, description, risk='low'):
        expires = datetime.now() + timedelta(hours=24)
        self.pending[change_id] = {
            'description': description,
            'risk': risk,
            'approved': False,
            'expires': expires
        }
        return change_id

    def approve(self, change_id, approver):
        if change_id in self.pending:
            req = self.pending[change_id]
            if datetime.now() < req['expires']:
                req['approved'] = True
                req['approver'] = approver
                return True
        return False

# Usage
approval = SimpleApproval()
req_id = approval.request('001', 'Add VLAN 100', 'medium')
approval.approve(req_id, 'manager@company.com')`
